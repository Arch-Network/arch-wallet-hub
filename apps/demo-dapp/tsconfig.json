{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@arch/wallet-hub-sdk": ["../../packages/wallet-hub-sdk/src/index.ts"],
      "@arch/wallet-hub-ui": ["../../packages/wallet-hub-ui/src/index.ts"]
    }
  },
  "include": ["src"]
}
