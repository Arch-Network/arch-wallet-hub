# Copy to .env.local and fill in values. NEVER commit real keys.
#
# These are quota-limited "platform" keys (not cryptographic secrets) baked
# into the extension bundle at build time. Treat them as discoverable by
# anyone who installs the extension; the trust root is the user's wallet
# keys, not these values.

# Wallet Hub (platform app gate). Set both in CI for the prod build.
WXT_HUB_API_KEY=
WXT_HUB_API_KEY_DEV=

# Arch Explorer Indexer (quota-limited public token).
WXT_INDEXER_API_KEY=
WXT_INDEXER_API_KEY_DEV=
