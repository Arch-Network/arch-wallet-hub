# Copy to .env.local and fill in values. NEVER commit real keys.
#
# All EXPO_PUBLIC_* values are bundled into the release APK/IPA and are
# recoverable from a public install. They are quota-gates, not secrets.

EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_API_BASE_URL_WEB=http://localhost:3005
EXPO_PUBLIC_API_KEY=
