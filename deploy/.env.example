# Database
DB_USER=wallet_hub
DB_PASSWORD=your_secure_password_here
DB_NAME=wallet_hub

# API Configuration
API_KEY=your_api_key_here

# Turnkey Configuration
TURNKEY_API_PUBLIC_KEY=your_turnkey_public_key
TURNKEY_API_PRIVATE_KEY=your_turnkey_private_key
TURNKEY_ORGANIZATION_ID=your_turnkey_org_id

# Arch Network
ARCH_RPC_URL=https://rpc.testnet.arch.network

# Explorer / Indexer
INDEXER_BASE_URL=https://explorer.arch.network/api/v1/testnet
INDEXER_API_KEY=
INDEXER_TIMEOUT_MS=30000

# Frontend API URL (set to the ALB DNS or EC2 public IP)
VITE_WALLET_HUB_BASE_URL=http://YOUR_HOST/v1

# Internal API key injected by nginx into proxied requests (docker-compose only)
INTERNAL_API_KEY=your_internal_api_key_here

# CORS
CORS_ALLOW_ORIGINS=*

# Arch transfer settings
ARCH_TRANSFER_REQUIRE_ANCHORED_UTXO=false
