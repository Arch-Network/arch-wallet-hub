NODE_ENV=development
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

# CORS
# Comma-separated list of allowed origins for browser-based dapps.
# In development, Wallet Hub also allows http://localhost:5173 and http://127.0.0.1:5173 by default.
# CORS_ALLOW_ORIGINS=https://your-dapp.example.com
CORS_ALLOW_ORIGINS=

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/arch_wallet_hub

# If true, the service will attempt to run DB migrations on boot.
# In production, prefer running migrations in a separate job.
DB_RUN_MIGRATIONS=false

# Turnkey (sandbox)
TURNKEY_BASE_URL=https://api.turnkey.com
TURNKEY_ORGANIZATION_ID=your_turnkey_org_id
TURNKEY_API_PUBLIC_KEY=your_turnkey_api_public_key
TURNKEY_API_PRIVATE_KEY=your_turnkey_api_private_key

# Arch indexer API (view-only reads, Phase 1)
# Use the base origin (recommended) or the /api/v1 root.
INDEXER_BASE_URL=https://explorer-beta.test.arch.network
# Optional. If provided, sent as both Authorization: Bearer <key> and X-API-Key: <key>
INDEXER_API_KEY=

# BTC Platform (served via Arch API platform)
# Example: http://localhost:3101
BTC_PLATFORM_BASE_URL=
# Optional. If provided, sent as both Authorization: Bearer <key> and X-API-Key: <key>
BTC_PLATFORM_API_KEY=

# Arch transfer execution depends on anchored BTC UTXOs. The validator may require a minimum
# confirmation count on the anchored UTXO before it can generate the underlying "transaction to sign".
# Wallet Hub uses this value for readiness checks and can return 409 until ready.
BTC_MIN_CONFIRMATIONS=20

# Backwards compat (deprecated)
TITAN_BASE_URL=
TITAN_API_KEY=
