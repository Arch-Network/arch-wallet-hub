NODE_ENV=development
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/arch_wallet_hub

# If true, the service will attempt to run DB migrations on boot.
# In production, prefer running migrations in a separate job.
DB_RUN_MIGRATIONS=false

# Turnkey (sandbox)
TURNKEY_BASE_URL=https://api.turnkey.com
TURNKEY_ORGANIZATION_ID=your_turnkey_org_id
TURNKEY_API_PUBLIC_KEY=your_turnkey_api_public_key
TURNKEY_API_PRIVATE_KEY=your_turnkey_api_private_key

# Arch indexer API (view-only reads, Phase 1)
# Use the base origin (recommended) or the /api/v1 root.
INDEXER_BASE_URL=https://explorer-beta.test.arch.network
# Optional. If provided, sent as both Authorization: Bearer <key> and X-API-Key: <key>
INDEXER_API_KEY=
